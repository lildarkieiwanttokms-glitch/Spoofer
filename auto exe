local function hoverAtTarget(target)
    local char = LocalPlayer.Character
    if not char then return end
    local rp = char:FindFirstChild("HumanoidRootPart")
    if not rp then return end

    local tRoot = target:FindFirstChild("HumanoidRootPart")
        or target:FindFirstChild("Torso") or target.PrimaryPart
    if not tRoot then return end

    local tPos = tRoot.Position
    local hoverPos

    if FarmMethod == "Behind" then
        -- Hover BEHIND the NPC's back (opposite of their LookVector), slightly elevated
        local back = -tRoot.CFrame.LookVector
        local distance = 4
        hoverPos = tPos + back * distance + Vector3.new(0, math.max(HoverHeight - 5, 1), 0)
    else
        -- Above the NPC
        hoverPos = tPos + Vector3.new(0, HoverHeight, 0)
    end

    -- Face NPC directly (head/face actually points at the NPC)
    rp.CFrame = CFrame.lookAt(hoverPos, tPos, Vector3.new(0, 1, 0))
    rp.AssemblyLinearVelocity = Vector3.zero
    rp.AssemblyAngularVelocity = Vector3.zero
end

local function findClosestSelectedNpc()
    local char = LocalPlayer.Character
    if not char then return nil end
    local rp = char:FindFirstChild("HumanoidRootPart")
    if not rp then return nil end

    local wanted = {}
    for displayName, enabled in pairs(SelectedNPCs) do
        if enabled then wanted[stripCount(displayName)] = true end
    end
    if not next(wanted) then return nil end

    -- Recompute anchors so we match the same display name as the dropdown
    local _, anchors = getNpcGroups()

    local best, bestDist = nil, math.huge
    for _, npc in ipairs(getAllValidNpcs()) do
        local display = getDisplayNameFor(npc.Name, anchors)
        if display and wanted[display] then
            local nrp = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if nrp then
                local d = (nrp.Position - rp.Position).Magnitude
                if d < bestDist then best, bestDist = npc, d end
            end
        end
    end
    return best
end

-- For Auto Farm All: closest VALID NPC within `range` studs (no selection filter).
local function findClosestValidNpc(range)
    local char = LocalPlayer.Character
    if not char then return nil end
    local rp = char:FindFirstChild("HumanoidRootPart")
    if not rp then return nil end

    local best, bestDist = nil, range or math.huge
    for _, npc in ipairs(getAllValidNpcs()) do
        local nrp = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
        if nrp then
            local d = (nrp.Position - rp.Position).Magnitude
            if d < bestDist then best, bestDist = npc, d end
        end
    end
    return best
end

