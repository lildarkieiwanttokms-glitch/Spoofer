-- Stand Reroll: uses Stand Arrow, waits, checks stand, notifies (3s) every roll,
-- and stops automatically once a desired stand is rolled.
-- Matching is aggressive: case + whitespace + punctuation stripped, AND substring
-- match in EITHER direction (handles "Star Platinum: The World" -> "Star Platinum",
-- internal IDs like "StarPlatinum_Variant_X", etc.).
local function normalizeStandName(s)
    if not s then return "" end
    return tostring(s):lower():gsub("[^%w]", "")
end

local function standsMatch(rolled, desired)
    local a = normalizeStandName(rolled)
    local b = normalizeStandName(desired)
    if a == "" or b == "" then return false end
    if a == b then return true end
    -- Substring either way (3-char minimum to avoid silly false positives)
    if #b >= 3 and a:find(b, 1, true) then return true end
    if #a >= 3 and b:find(a, 1, true) then return true end
    return false
end

task.spawn(function()
    while true do
        if AutoRerollOn and next(DesiredStands) then
            fireUseItem("Stand Arrow")
            task.wait(1.5)  -- let the server apply the new stand
            local current = getCurrentStand()
            if current and current ~= "" then
                Library:Notify("Got: " .. current, 3)
                local wanted, matchedName = false, nil
                for stand, on in pairs(DesiredStands) do
                    if on and standsMatch(current, stand) then
                        wanted = true; matchedName = stand; break
                    end
                end
                if wanted then
                    AutoRerollOn = false
                    DesiredStands = {}  -- clear so loop guard `next(DesiredStands)` also fails
                    pcall(function() Toggles.AutoReroll:SetValue(false) end)
                    pcall(function() Options.DesiredStands:SetValue({}) end)
                    Library:Notify("Got desired stand: " .. current
                        .. " (matched " .. matchedName .. ") — STOPPING!", 8)
                end
            end
            task.wait(0.3)
        else
            task.wait(0.3)
        end
    end
