local function addEsp(model, color, label)
    if not model or not model.Parent then return end
    if model:FindFirstChild("__JJEsp") then return end

    local hl = Instance.new("Highlight")
    hl.Name = "__JJEsp"
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.7
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = model

    local head = model:FindFirstChild("Head") or model:FindFirstChildWhichIsA("BasePart")
    if head then
        local bb = Instance.new("BillboardGui")
        bb.Name = "__JJEspTag"
        bb.Adornee = head
        bb.Size = UDim2.new(0, 130, 0, 32)
        bb.StudsOffset = Vector3.new(0, 2, 0)
        bb.AlwaysOnTop = true
        bb.Parent = model

        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 1
        tl.Size = UDim2.fromScale(1, 1)
        tl.Text = label
        tl.TextColor3 = color
        tl.TextStrokeTransparency = 0
        tl.TextStrokeColor3 = Color3.new(0, 0, 0)
        tl.Font = Enum.Font.GothamBold
        tl.TextScaled = true
        tl.Parent = bb
    end
end

local function removeEsp(model)
    if not model then return end
    local hl = model:FindFirstChild("__JJEsp")
    if hl then hl:Destroy() end
    local tag = model:FindFirstChild("__JJEspTag")
    if tag then tag:Destroy() end
end

local function clearAllEsp()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then removeEsp(p.Character) end
    end
    for _, npc in ipairs(workspace:GetDescendants()) do
        if npc:IsA("Model") then removeEsp(npc) end
    end
end

