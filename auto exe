local function extractStandFromTable(t, depth)
    depth = depth or 0
    if depth > 3 then return nil end
    if type(t) ~= "table" then return nil end

    for _, k in ipairs({"stand", "Stand", "name", "Name", "standName",
                        "StandName", "Type", "type", "currentStand", "CurrentStand"}) do
        local v = t[k]
        if type(v) == "string" and #v > 0 then return v end
        if type(v) == "table" then
            local sub = extractStandFromTable(v, depth + 1)
            if sub then return sub end
        end
    end
    -- fallback: any string value
    for _, v in pairs(t) do
        if type(v) == "string" and #v > 0 and #v < 60 then return v end
    end
    return nil
end

local function readInstanceValue(inst)
    if not inst then return nil end
    if inst:IsA("ValueBase") then
        local v = inst.Value
        if v and tostring(v) ~= "" then return tostring(v) end
    end
    for _, attr in ipairs({"Value", "Name", "Stand", "StandName"}) do
        local v = inst:GetAttribute(attr)
        if v and tostring(v) ~= "" then return tostring(v) end
    end
    return nil
end

local function getCurrentStand()
    -- PRIMARY: PlayerData.SlotData.Stand (per user)
    local pd = LocalPlayer:FindFirstChild("PlayerData")
    if pd then
        local sd = pd:FindFirstChild("SlotData")
        if sd then
            local stand = sd:FindFirstChild("Stand")
            local v = readInstanceValue(stand)
            if v then return v end
        end
    end

    -- Fallback: get_data remote
    local result = nil
    pcall(function()
        result = ReplicatedStorage:WaitForChild("requests", 5)
            :WaitForChild("miscellaneous", 5)
            :WaitForChild("get_data", 5)
            :InvokeServer("stand")
    end)
    if type(result) == "string" and #result > 0 then return result end
    if type(result) == "table" then
        local v = extractStandFromTable(result)
        if v then return v end
    end

    -- Fallback: character attributes
    local char = LocalPlayer.Character
    if char then
        for _, attr in ipairs({"Stand", "StandName", "stand", "CurrentStand"}) do
            local v = char:GetAttribute(attr)
            if v and tostring(v) ~= "" then return tostring(v) end
        end
    end

    -- Fallback: any child of PlayerData/Data/leaderstats whose name contains "stand"
    for _, container in ipairs({LocalPlayer:FindFirstChild("PlayerData"),
                                LocalPlayer:FindFirstChild("Data"),
                                LocalPlayer:FindFirstChild("leaderstats")}) do
        if container then
            for _, c in ipairs(container:GetDescendants()) do
                if c.Name:lower():find("stand") and c:IsA("ValueBase") then
                    local v = c.Value
                    if v and tostring(v) ~= "" then return tostring(v) end
                end
            end
        end
    end

    return nil
end

