-- ============================================================
-- AUTO PICKUP + ITEM SPAWN NOTIFY
-- ============================================================
local function matchPickupName(rawName)
    if not rawName then return nil end
    local key = rawName:lower()
    -- Exact match first
    if PickupItemSet[key] then return PickupItemSet[key] end
    -- Substring match (e.g. "Stand Arrow_Drop_123" contains "stand arrow")
    for k, pretty in pairs(PickupItemSet) do
        if key:find(k, 1, true) then return pretty end
    end
    return nil
end

local function isItemSpawn(obj)
    if not obj or not obj.Parent then return nil end
    if obj:IsA("Tool") or obj:IsA("Model") or obj:IsA("BasePart") then
        return matchPickupName(obj.Name)
    end
    return nil
end

local function getItemPosition(obj)
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then
        local part = obj.PrimaryPart
            or obj:FindFirstChild("HumanoidRootPart")
            or obj:FindFirstChildWhichIsA("BasePart", true)
        if part then return part.Position end
    end
    if obj:IsA("Tool") then
        local handle = obj:FindFirstChild("Handle")
        if handle then return handle.Position end
    end
    return nil
end

local SeenSpawns = setmetatable({}, { __mode = "k" })  -- weak keys; auto-clean

local function tryPickup(obj, itemName)
    -- Strategy 1: ProximityPrompt
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and fireproximityprompt then
        pcall(function() fireproximityprompt(prompt, 1) end)
        return true
    end
    -- Strategy 2: ClickDetector
    local click = obj:FindFirstChildWhichIsA("ClickDetector", true)
    if click and fireclickdetector then
        pcall(function() fireclickdetector(click, 0) end)
        return true
    end
    -- Strategy 3: Brief teleport-touch (Tools and Touch-pickup items)
    local pos = getItemPosition(obj)
    local mrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if pos and mrp then
        local original = mrp.CFrame
        for _ = 1, 3 do
            mrp.CFrame = CFrame.new(pos)
            task.wait(0.15)
            if not obj.Parent then break end
        end
        -- Don't restore — user is now near it on purpose
        return true
    end
    return false
end

workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.4)  -- let attributes/children settle
    if not obj or not obj.Parent then return end
    local itemName = isItemSpawn(obj)
    if not itemName then return end
    if SeenSpawns[obj] then return end
    SeenSpawns[obj] = true

    if NotifySpawnsOn then
        Library:Notify(itemName .. " spawned!", 4)
    end

    if AutoPickupOn then
        task.spawn(function()
            local ok = tryPickup(obj, itemName)
            task.wait(0.4)
            if ok then
                Library:Notify("Picked up: " .. itemName, 3)
            end
        end)
    end
end)

