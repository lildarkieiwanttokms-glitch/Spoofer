-- Auto Retry Raid: only fires the retryraid remote when there are no NPCs
-- alive NEAR the player (i.e. the raid arena is cleared). We use a distance
-- check so that lobby NPCs (shopkeepers, quest givers, etc.) don't block it.
local RETRY_NPC_RANGE = 250  -- studs

local function noNpcsAliveNearby()
    local char = LocalPlayer.Character
    local rp = char and char:FindFirstChild("HumanoidRootPart")
    if not rp then
        -- Character not loaded -> treat as "nothing alive" so retry can fire
        return true
    end
    for _, npc in ipairs(getAllValidNpcs()) do
        local nrp = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
        if nrp and (nrp.Position - rp.Position).Magnitude <= RETRY_NPC_RANGE then
            return false
        end
    end
    return true
end

task.spawn(function()
    while true do
        if AutoRetryRaidOn then
            if noNpcsAliveNearby() then
                fireRetryRaid()
                task.wait(RetryRaidDelay)
            else
                -- Wait until the raid arena is cleared before retrying
                task.wait(0.5)
            end
        else
            task.wait(0.3)
        end
    end
end)

