-- Smart re-summon loop:
-- - Requires FOUR consecutive missing checks (~3 sec) before firing
-- - 8-second cooldown after firing
-- - Re-checks RIGHT BEFORE firing using the strongest detection (incl. cached model)
--   so we never toggle off a stand we just summoned
local lastSummonFire = 0
local SUMMON_COOLDOWN = 8
local missingStreak = 0

task.spawn(function()
    while task.wait(0.7) do
        if not AutoSummonOn then
            missingStreak = 0
        else
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                if isStandActive() then
                    missingStreak = 0
                else
                    missingStreak = missingStreak + 1
                    if missingStreak >= 4 and (tick() - lastSummonFire) > SUMMON_COOLDOWN then
                        -- Final paranoid double-check before firing the toggle remote
                        task.wait(0.2)
                        if not isStandActive() then
                            fireSummonStand()
                            lastSummonFire = tick()
                        end
                        missingStreak = 0
                    end
                end
            end
        end
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    missingStreak = 0
    lastSummonFire = 0
    CachedStandModel = nil
    if AutoSummonOn then
        task.wait(3)
        if not isStandActive() then
            fireSummonStand()
            lastSummonFire = tick()
        end
    end
end)

