-- Apply walk speed / jump power EVERY HEARTBEAT (prevents game from overriding it)
-- Also hooks GetPropertyChangedSignal for instant re-correction.
local function applyMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if WalkSpeedOn and hum.WalkSpeed ~= WalkSpeedVal then
        hum.WalkSpeed = WalkSpeedVal
    end
    if JumpPowerOn then
        if not hum.UseJumpPower then hum.UseJumpPower = true end
        if hum.JumpPower ~= JumpPowerVal then hum.JumpPower = JumpPowerVal end
    end
end
RunService.Heartbeat:Connect(applyMovement)

local function hookHumanoid(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if WalkSpeedOn and hum.WalkSpeed ~= WalkSpeedVal then
            hum.WalkSpeed = WalkSpeedVal
        end
    end)
    hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if JumpPowerOn and hum.JumpPower ~= JumpPowerVal then
            hum.JumpPower = JumpPowerVal
        end
    end)
end
if LocalPlayer.Character then hookHumanoid(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(function(c) task.wait(0.5); hookHumanoid(c); applyMovement() end)

