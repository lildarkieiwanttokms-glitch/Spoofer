-- STAND ACTIVE DETECTION (multi-method, cached, no false negatives)
-- ============================================================
local CachedStandModel = nil  -- Once we find it, remember it for fast re-checks

local function _findStandInContainer(container)
    if not container then return nil end
    -- Direct child by player name
    local direct = container:FindFirstChild(LocalPlayer.Name)
    if direct then return direct end

    -- Scan children for owner-style attributes / matching name
    for _, m in ipairs(container:GetChildren()) do
        local owner = m:GetAttribute("Owner") or m:GetAttribute("OwnerId")
            or m:GetAttribute("UserId") or m:GetAttribute("PlayerId")
        local ownerName = m:GetAttribute("OwnerName")
            or m:GetAttribute("Player") or m:GetAttribute("PlayerName")
        if owner == LocalPlayer.UserId
            or ownerName == LocalPlayer.Name
            or m.Name == LocalPlayer.Name
            or m.Name == tostring(LocalPlayer.UserId) then
            return m
        end
        -- Some games nest player name inside the stand model
        if m:FindFirstChild(LocalPlayer.Name) then return m end
    end
    return nil
end

local function isStandActive()
    local char = LocalPlayer.Character
    if not char then return false end

    -- 0. Cached model (fast path)
    if CachedStandModel and CachedStandModel.Parent then
        local hum = CachedStandModel:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then return true end
        CachedStandModel = nil  -- invalid, fall through to re-detect
    end

    -- 1. Common workspace stand containers
    for _, folderName in ipairs({"Stands", "stands", "Stand", "ActiveStands",
                                  "SummonedStands", "Pets"}) do
        local folder = workspace:FindFirstChild(folderName)
        local found = _findStandInContainer(folder)
        if found then CachedStandModel = found; return true end
    end

    -- 2. Character holds the stand as a child Model with Humanoid
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChildOfClass("Humanoid")
            and child ~= char then
            CachedStandModel = child
            return true
        end
    end

    -- 3. Character attributes set when a stand is out
    for _, attr in ipairs({"StandActive", "StandSummoned", "HasStand",
                           "StandOut", "Summoned", "Active"}) do
        local v = char:GetAttribute(attr)
        if v == true then return true end
    end

    -- 4. PlayerData / SlotData attributes & ValueBase children
    for _, container in ipairs({LocalPlayer:FindFirstChild("PlayerData"),
                                LocalPlayer:FindFirstChild("Data")}) do
        if container then
            for _, attr in ipairs({"StandActive", "StandSummoned", "Summoned",
                                   "HasStand", "Active"}) do
                local v = container:GetAttribute(attr)
                if v == true then return true end
            end
            for _, c in ipairs(container:GetDescendants()) do
                local n = c.Name:lower()
                if c:IsA("ValueBase")
                    and n:find("stand")
                    and (n:find("active") or n:find("summon") or n:find("out")) then
                    if c.Value == true or c.Value == 1 then return true end
                end
            end
        end
    end

    -- 5. Look at character's Motor6D — when stand is summoned, some games attach
    --    a stand body to the torso via Motor6D named like "StandWeld" / "Stand"
    local torso = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if torso then
        for _, c in ipairs(torso:GetChildren()) do
            if c:IsA("Motor6D") or c:IsA("Weld") then
                local n = c.Name:lower()
                if n:find("stand") and c.Part1 then return true end
            end
        end
    end

    return false
end

-- ============================================================
-- NPC HELPERS (validity + name normalization + grouping)
-- ============================================================

-- Skip dummies/decorations: must have a real, finite, positive HP
local function isValidNpc(model)
    if not model or not model:IsA("Model") then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    if hum.MaxHealth == math.huge or hum.MaxHealth <= 0 then return false end
    if hum.Health == math.huge or hum.Health <= 0 then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Torso") or model.PrimaryPart
    if not hrp then return false end
    return true
end

-- Split CamelCase: "OfficerQjJW" -> {"Officer", "Qj", "JW"}
local function splitCamelCase(word)
    local parts, current = {}, ""
    for i = 1, #word do
        local c = word:sub(i, i)
        local prev = i > 1 and word:sub(i - 1, i - 1) or ""
        if c:match("%u") and prev:match("[%l%d]") then
            if #current > 0 then table.insert(parts, current) end
            current = c
        else
            current = current .. c
        end
    end
    if #current > 0 then table.insert(parts, current) end
    return parts
end

-- Detects random / gibberish word fragments like "QjJW", "Tajkgu", "ZdzuB"
local function isLikelyGarbage(word)
    if #word <= 1 then return true end
    -- Internal uppercase (after first char) usually means random ID
    if word:sub(2):match("%u") then return true end
    -- Count vowels
    local vowels = 0
    for _ in word:lower():gmatch("[aeiouy]") do vowels = vowels + 1 end
    -- No vowels and longer than 2 chars -> garbage (e.g. "JW", "BzG")
    if vowels == 0 and #word > 2 then return true end
    -- Very low vowel ratio (< 20%) for moderate length words -> garbage
    if #word >= 4 and (vowels / #word) < 0.2 then return true end
    return false
end

-- Strip trailing "junk" words (no vowels, very short, or obvious gibberish like "Tr", "Br", "Vr")
local function stripTrailingJunkWords(name)
    local words = {}
    for w in name:gmatch("%S+") do table.insert(words, w) end
    while #words > 1 do
        local last = words[#words]
        local lower = last:lower()
        local vowels = 0
        for _ in lower:gmatch("[aeiouy]") do vowels = vowels + 1 end
        local isJunk = false
        if #last <= 3 and vowels == 0 then isJunk = true end
        if #last <= 2 then isJunk = true end
        if vowels == 0 and #last <= 4 then isJunk = true end
        if isJunk then table.remove(words, #words) else break end
    end
    return table.concat(words, " ")
end

-- Cleans a single NPC name: special chars -> space, strip digits, split camelCase, drop garbage,
-- then strip trailing junk words.
local function normalizeNpcName(name)
    if not name or name == "" then return nil end
    local cleaned = name:gsub("[^%w%s]", " ")
    local words = {}
    for raw in cleaned:gmatch("%S+") do
        raw = raw:gsub("^%d+", ""):gsub("%d+$", "")
        if raw:match("%a") then
            local parts = splitCamelCase(raw)
            for _, p in ipairs(parts) do
                p = p:gsub("%d+", "")
                if p:match("%a") and not isLikelyGarbage(p) then
                    table.insert(words, p)
                end
            end
        end
    end
    if #words == 0 then return nil end
    local joined = table.concat(words, " ")
    joined = stripTrailingJunkWords(joined)
    if joined == "" then return nil end
    return joined
end

-- Scans only workspace.Live (skips workspace.Npcs as requested)
local function getAllValidNpcs()
    local npcs = {}
    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end

    local liveFolder = workspace:FindFirstChild("Live")
        or workspace:FindFirstChild("live")
    if not liveFolder then return npcs end

    for _, obj in ipairs(liveFolder:GetDescendants()) do
        if obj:IsA("Humanoid") then
            local model = obj.Parent
            if model and not playerChars[model] and isValidNpc(model) then
                table.insert(npcs, model)
            end
        end
    end
    return npcs
end

-- Longest common prefix (case-insensitive)
local function lcpStr(a, b)
    local n = math.min(#a, #b)
    local match = 0
    for j = 1, n do
        if a:sub(j, j):lower() == b:sub(j, j):lower() then
            match = j
        else
            break
        end
    end
    return a:sub(1, match)
end

-- After computing an LCP that ends mid-word, clean up trailing duplicate letters
-- and any 1-2 char dangling suffix. "Prison Escapee" -> "Prison Escape".
local function cleanPartialPrefix(prefix)
    -- Strip trailing repeated identical letters (collapses "ee" -> "e")
    prefix = prefix:gsub("(%a)%1+$", "%1")
    return prefix
end

-- Returns the "clean" form of an LCP for use as a group key.
-- If the LCP ends on a word boundary in any of its source names, use it as-is.
-- Otherwise, try cleaned partial; if that's still mid-word, fall back to last
-- whole word(s).
local function trimLcpToCleanKey(prefix, sourceList)
    if prefix == "" then return prefix end
    -- ends on word boundary?
    local endsClean = false
    for _, n in ipairs(sourceList) do
        if n == prefix or (#n > #prefix and n:sub(#prefix + 1, #prefix + 1):match("%s")) then
            endsClean = true
            break
        end
    end
    if endsClean then
        return prefix:gsub("%s+$", "")
    end
    -- mid-word: clean trailing dup letters first
    local cleaned = cleanPartialPrefix(prefix)
    if #cleaned >= 4 then return cleaned end
    -- still too short / messy: fall back to last whole word(s)
    local fallback = prefix:match("^(.+)%s%S+$")
    return fallback or prefix
end

-- Build anchor base-names by combining two strategies:
--   a) Any normalized name that's a prefix of >=2 names (handles "Boxer" / "Boxerz Tr")
--   b) For each first-word cluster of >=2 names, compute the LCP and use a
--      cleaned form (handles "Prison Escapeedn" + "Prison Escapeemdz" -> "Prison Escape")
local function buildAnchors(normalizedList)
    local anchors = {}

    -- Strategy A: prefix-of-others
    for _, candidate in ipairs(normalizedList) do
        if #candidate >= 4 and not anchors[candidate] then
            local count = 0
            for _, other in ipairs(normalizedList) do
                if other == candidate
                    or other:sub(1, #candidate):lower() == candidate:lower() then
                    count = count + 1
                end
            end
            if count >= 2 then anchors[candidate] = count end
        end
    end

    -- Strategy B: first-word clusters -> LCP
    local clusters = {}
    for _, name in ipairs(normalizedList) do
        local fw = (name:match("^(%S+)") or name):lower()
        clusters[fw] = clusters[fw] or {}
        table.insert(clusters[fw], name)
    end
    for _, list in pairs(clusters) do
        if #list >= 2 then
            local prefix = list[1]
            for i = 2, #list do
                prefix = lcpStr(prefix, list[i])
                if prefix == "" then break end
            end
            if prefix ~= "" then
                local key = trimLcpToCleanKey(prefix, list)
                key = key:gsub("%s+$", "")
                if #key >= 3 and not anchors[key] then
                    anchors[key] = #list
                end
            end
        end
    end

    return anchors
end

local function collapseUnderAnchor(name, anchors)
    -- Find the LONGEST anchor that is a (case-insensitive) prefix of this name
    local best = nil
    local lower = name:lower()
    for anchor, _ in pairs(anchors) do
        if lower:sub(1, #anchor) == anchor:lower() then
            if not best or #anchor > #best then best = anchor end
        end
    end
    return best or name
end

local function getDisplayNameFor(rawName, anchors)
    local norm = normalizeNpcName(rawName)
    if not norm then return nil end
    return collapseUnderAnchor(norm, anchors)
end

local function getNpcGroups()
    local normalizedList = {}
    for _, npc in ipairs(getAllValidNpcs()) do
        local n = normalizeNpcName(npc.Name)
        if n then table.insert(normalizedList, n) end
    end

    local anchors = buildAnchors(normalizedList)

    local groups = {}
    for _, n in ipairs(normalizedList) do
        local key = collapseUnderAnchor(n, anchors)
        groups[key] = (groups[key] or 0) + 1
    end
    return groups, anchors
end

local function buildNpcDropdownValues()
    local groups = getNpcGroups()
    local list = {}
    for name, count in pairs(groups) do
        table.insert(list, name .. "  ×" .. count)
    end
    table.sort(list)
    return list
end

local function stripCount(displayName)
    return (displayName:gsub("%s+×%d+$", ""))
end

