-- AUTO-DISMISS "GAMEPLAY PAUSED" OVERLAY
-- ============================================================
local function dismissPausedOverlay()
    -- Look for the GuiService notification text in CoreGui
    local function clickAll(root)
        if not root then return end
        for _, gui in ipairs(root:GetDescendants()) do
            if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                local txt = ""
                if gui:IsA("TextButton") then txt = gui.Text or "" end
                local check = (txt .. " " .. gui.Name):lower()
                if check:find("resume") or check:find("paused")
                    or check:find("tap to") or check:find("continue") then
                    pcall(function()
                        if firesignal then firesignal(gui.MouseButton1Click) end
                    end)
                end
            end
        end
    end
    pcall(function() clickAll(LocalPlayer:FindFirstChildOfClass("PlayerGui")) end)
    pcall(function() clickAll(CoreGui) end)
end

task.spawn(function()
    while task.wait(1.5) do
        if AutoDismissPaused then
            -- Quick check: only act if any "Resume Game" text exists somewhere
            local found = false
            pcall(function()
                for _, root in ipairs({LocalPlayer:FindFirstChildOfClass("PlayerGui"), CoreGui}) do
                    if root then
                        for _, lbl in ipairs(root:GetDescendants()) do
                            if (lbl:IsA("TextLabel") or lbl:IsA("TextButton")) then
                                local t = (lbl.Text or ""):lower()
                                if t:find("paused") or t:find("resume") or t:find("tap to") then
                                    found = true; break
                                end
                            end
                        end
                    end
                    if found then break end
                end
            end)
            if found then dismissPausedOverlay() end
        end
    end
end)

