local script_url = "https://raw.githubusercontent.com/lildarkieiwanttokms-glitch/Spoofer/refs/heads/main/text.txt"

-- Execute the script immediately for the current game
loadstring(game:HttpGet(script_url))()

-- Queue the script to execute again after a teleport
if queue_on_teleport then
    queue_on_teleport('loadstring(game:HttpGet("' .. script_url .. '"))()')
else
    print("Your executor does not support queue_on_teleport.")
end
